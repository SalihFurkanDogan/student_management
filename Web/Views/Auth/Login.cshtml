@using Application.DTOs.Login
@model LoginDTO

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_Layout"; // Varsa boş bir layout kullanabilirsin
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="text-center mb-4">🔐 Sisteme Giriş</h3>
                
                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3 text-center"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">E-Posta Adresi</label>
                        <input asp-for="Email" type="email" class="form-control" required placeholder="admin@ogr.edu.tr" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-bold">Şifre</label>
                        <input asp-for="Password" type="password" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg">Giriş Yap</button>
                </form>
            </div>
        </div>
    </div>
</div>