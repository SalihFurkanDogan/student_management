@using Application.DTOs.Attendance
@model AttendanceCreateDTO

@{
    ViewData["Title"] = "Yoklama Girişi";
}

<div class="container mt-4">
    <h2>📝 Yoklama Girişi</h2>
    <hr />

    <div class="row">
        <div class="col-md-5 shadow-sm p-4 bg-light rounded">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="EnrollmentId" class="form-label fw-bold">Kayıt ID (Enrollment ID)</label>
                    <input asp-for="EnrollmentId" type="number" class="form-control" required />
                    <small class="text-muted">Hangi öğrencinin hangi dersteki kaydına yoklama giriyorsunuz?</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Date" class="form-label fw-bold">Tarih</label>
                    <input asp-for="Date" type="date" class="form-control" required />
                </div>

                <div class="mb-4 form-check form-switch fs-5">
                    <input asp-for="IsPresent" class="form-check-input" type="checkbox" id="isPresentSwitch">
                    <label class="form-check-label fw-bold" for="isPresentSwitch">
                        Öğrenci Derse Katıldı (Var)
                    </label>
                </div>

                <div class="d-grid mt-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save"></i> Yoklamayı Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>