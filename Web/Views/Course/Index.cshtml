@using Application.DTOs.Course
@model IEnumerable<CourseListDTO>

@{
    ViewData["Title"] = "Ders Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📚 Ders Listesi</h2>
        @if (User.Identity is not null && User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Yeni Ders Ekle
            </a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Ders Kodu</th>
                        <th>Ders Adı</th>
                        <th>Kredi</th>
                        <th>Kontenjan</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Henüz sisteme eklenmiş bir ders bulunmamaktadır.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var course in Model)
                        {
                            <tr>
                                <td><strong>@course.Code</strong></td>
                                <td>@course.Name</td>
                                <td>@course.Credit</td>
                                <td>@course.Quota</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-outline-warning">Düzenle</a>
                                    <a href="#" class="btn btn-sm btn-outline-danger">Sil</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>