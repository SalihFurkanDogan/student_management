@using Application.DTOs.Course
@model CourseCreateDTO

@{
    ViewData["Title"] = "Yeni Ders Ekle";
}

<div class="container mt-4">
    <h2>➕ Yeni Ders Ekle</h2>
    <hr />

    <div class="row">
        <div class="col-md-6 shadow-sm p-4 bg-light rounded">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Code" class="form-label text-primary fw-bold">Ders Kodu</label>
                    <input asp-for="Code" class="form-control" placeholder="Örn: BIL101" required />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label text-primary fw-bold">Ders Adı</label>
                    <input asp-for="Name" class="form-control" placeholder="Örn: Algoritma ve Programlama" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Credits" class="form-label fw-bold">Kredi</label>
                        <input asp-for="Credits" type="number" class="form-control" min="1" max="10" required />
                        <span asp-validation-for="Credits" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Quota" class="form-label fw-bold">Kontenjan</label>
                        <input asp-for="Quota" type="number" class="form-control" min="10" max="250" required />
                        <span asp-validation-for="Quota" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="DepartmentId" class="form-label fw-bold">Departman ID</label>
                        <input asp-for="DepartmentId" type="number" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="InstructorId" class="form-label fw-bold">Eğitmen ID</label>
                        <input asp-for="InstructorId" type="number" class="form-control" required />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success w-50">
                        <i class="bi bi-save"></i> Kaydet
                    </button>
                    <a asp-action="Index" class="btn btn-secondary w-50">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>